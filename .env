# ─── Seguridad ────────────────────────────────────────────────────────────────
# Generá una clave segura con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-antes-de-produccion

# ─── Email (para notificaciones) ──────────────────────────────────────────────
# Ejemplo con Gmail: activá "Contraseñas de aplicación" en tu cuenta Google
MAIL_ENABLED=false
MAIL_FROM=noreply@tucentro.com
MAIL_FROM_NAME=MediPortal
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_contraseña_de_app

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=MediPortal
APP_URL=http://localhost:8000
